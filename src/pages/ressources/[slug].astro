---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import CTASection from '../../components/CTASection.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides', ({ data }) => !data.draft);
  return guides.map((guide) => ({ params: { slug: guide.id }, props: { guide } }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
const { data } = guide;

const siteOrigin = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(`/ressources/${guide.id}`, siteOrigin).href;
const dateFmt = (d: Date) => new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);
const fondsHref = `/recherche?q=${encodeURIComponent(data.fondsQuery ?? data.category)}`;

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title,
  description: data.description,
  datePublished: data.publishedDate.toISOString(),
  ...(data.updatedDate ? { dateModified: data.updatedDate.toISOString() } : {}),
  inLanguage: 'fr',
  articleSection: data.category,
  author: { '@type': 'Organization', name: 'Mibeko' },
  publisher: { '@type': 'Organization', name: 'Mibeko', logo: { '@type': 'ImageObject', url: new URL('/logo.svg', siteOrigin).href } },
  mainEntityOfPage: canonical,
  ...(data.cover ? { image: new URL(data.cover.src, siteOrigin).href } : {}),
};
---

<Layout
	title={`${data.title} — Mibeko`}
	description={data.description}
	ogType="article"
	canonical={canonical}
	jsonLd={[articleLd]}
>
	<Header />
	<main id="main" class="flex-grow bg-background">

    <header class="pt-24 pb-16 md:pt-32 md:pb-24 relative overflow-hidden">
      <div class="absolute inset-0 z-0">
        {data.cover && (
          <Image src={data.cover} alt="" width={1280} loading="eager" class="w-full h-full object-cover object-center opacity-30" />
        )}
        <div class="absolute inset-0 bg-gradient-to-b from-background/90 via-background/95 to-background"></div>
      </div>

      <div class="max-w-[800px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center animate-fade-in-up">
        <div class="flex items-center justify-center gap-3 mb-6">
          <span class="inline-flex items-center px-3 py-1 rounded-full bg-secondary/10 border border-secondary/20 text-secondary text-xs font-bold tracking-wide uppercase">{data.category}</span>
          <span class="text-sm text-on-surface-variant font-medium">{dateFmt(data.publishedDate)}</span>
        </div>
        <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold text-on-surface tracking-tight mb-8 leading-[1.15]">{data.title}</h1>
        <p class="text-xl text-on-surface-variant font-serif leading-relaxed">{data.description}</p>
      </div>
    </header>

    <article class="pb-20 md:pb-28">
      <div class="max-w-[760px] mx-auto px-4 sm:px-6 lg:px-8 animate-fade-in-up animation-delay-200">
        {data.cover && (
          <div class="w-full rounded-3xl overflow-hidden mb-16 border border-surface-variant shadow-lg">
            <Image src={data.cover} alt={data.title} width={1280} loading="eager" class="w-full h-auto object-cover aspect-video" />
          </div>
        )}

        <div class="legal-prose mx-auto">
          <Content />
        </div>

        <!-- Pont éditorial → fonds officiel -->
        <div class="mt-14 rounded-2xl border border-surface-variant bg-surface-container-low p-8">
          <h2 class="text-lg font-bold text-on-surface mb-2">Consultez les textes officiels</h2>
          <p class="text-sm text-on-surface-variant mb-6">Ce guide explique les grands principes. Pour le détail, accédez aux textes en vigueur dans le fonds Mibeko.</p>
          <div class="flex flex-wrap gap-3">
            <a href={fondsHref} class="inline-flex items-center h-10 px-5 bg-primary text-on-primary font-semibold rounded hover:bg-primary-container transition-colors text-sm">Rechercher dans le fonds</a>
            <a href="/textes" class="inline-flex items-center h-10 px-5 bg-surface-container text-on-surface font-semibold rounded hover:bg-surface-container-high transition-colors text-sm">Parcourir les textes officiels</a>
          </div>
        </div>

        <div class="mt-12 pt-8 border-t border-surface-variant">
          <a href="/ressources" class="inline-flex items-center gap-2 text-on-surface-variant hover:text-primary font-semibold transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg>
            Tous les guides
          </a>
        </div>
      </div>
    </article>

		<CTASection title="Ne manquez aucune évolution du droit" text="Avec Mibeko, recevez les actualités juridiques qui vous concernent directement dans votre espace." />
	</main>
	<Footer />
</Layout>
