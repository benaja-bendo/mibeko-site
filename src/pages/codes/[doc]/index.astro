---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { fetchPublicDocument, documentPath, articlePath } from '../../../lib/api';

const { doc } = Astro.params;
const payload = doc ? await fetchPublicDocument(doc) : null;
const notFound = !payload;

if (notFound) {
  Astro.response.status = 404;
}

const siteOrigin = Astro.site ?? new URL(Astro.url.origin);
const document = payload?.document;
const articles = payload?.articles ?? [];

const typeName = document?.type?.name ?? 'Texte juridique';
const selfUrl = document ? new URL(documentPath(document.slug), siteOrigin).href : '';

const dateFmt = (iso?: string | null) =>
  iso ? new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(iso)) : null;

const legislationLd = document
  ? {
      '@context': 'https://schema.org',
      '@type': 'Legislation',
      name: document.titre_officiel,
      legislationType: typeName,
      legislationJurisdiction: { '@type': 'AdministrativeArea', name: 'République du Congo' },
      inLanguage: 'fr',
      url: selfUrl,
      ...(document.reference_nor ? { legislationIdentifier: document.reference_nor } : {}),
      ...(document.date_publication ? { datePublished: document.date_publication } : {}),
    }
  : null;

const breadcrumbLd = document
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Accueil', item: new URL('/', siteOrigin).href },
        { '@type': 'ListItem', position: 2, name: 'Codes & lois', item: new URL('/codes', siteOrigin).href },
        { '@type': 'ListItem', position: 3, name: document.titre_officiel, item: selfUrl },
      ],
    }
  : null;

const jsonLd = [legislationLd, breadcrumbLd].filter(Boolean) as Record<string, unknown>[];
---

<Layout
  title={notFound ? 'Texte introuvable — Mibeko' : `${document!.titre_officiel} — Mibeko`}
  description={notFound
    ? "Ce texte n'est pas disponible dans le fonds Mibeko."
    : `${document!.titre_officiel} — ${typeName} de la République du Congo. ${articles.length} articles, consultables librement sur Mibeko.`}
  ogType="article"
  canonical={selfUrl || undefined}
  jsonLd={jsonLd}
>
  <Header />
  <main id="main" class="flex-grow bg-background">
    {notFound ? (
      <section class="max-w-[700px] mx-auto px-4 sm:px-6 lg:px-8 py-32 text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-secondary mb-4">Erreur 404</p>
        <h1 class="text-3xl md:text-4xl font-bold text-on-surface mb-6">Ce texte est introuvable</h1>
        <a href="/codes" class="inline-flex items-center h-11 px-6 bg-primary text-on-primary font-semibold rounded hover:bg-primary-container transition-colors">
          Parcourir le fonds juridique
        </a>
      </section>
    ) : (
      <div class="max-w-[860px] mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">

        <nav aria-label="Fil d'Ariane" class="text-sm text-on-surface-variant mb-8 flex flex-wrap items-center gap-1.5">
          <a href="/" class="hover:text-primary transition-colors">Accueil</a>
          <span class="text-outline">/</span>
          <a href="/codes" class="hover:text-primary transition-colors">Codes &amp; lois</a>
          <span class="text-outline">/</span>
          <span class="text-on-surface font-medium line-clamp-1">{document!.titre_officiel}</span>
        </nav>

        <header class="mb-12 pb-10 border-b border-surface-variant">
          <div class="flex flex-wrap items-center gap-3 mb-5">
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-secondary/10 text-secondary text-xs font-bold tracking-wide uppercase">{typeName}</span>
            {document!.date_publication && <span class="text-sm text-on-surface-variant">Publié le {dateFmt(document!.date_publication)}</span>}
            {document!.reference_nor && <span class="text-sm text-outline">Réf. {document!.reference_nor}</span>}
          </div>
          <h1 class="text-3xl md:text-5xl font-bold text-on-surface tracking-tight leading-tight mb-6">{document!.titre_officiel}</h1>
          <div class="flex flex-wrap gap-x-8 gap-y-2 text-sm text-on-surface-variant">
            {document!.institution?.nom && <span><span class="text-outline">Institution :</span> {document!.institution.nom}</span>}
            <span><span class="text-outline">Articles :</span> {articles.length}</span>
            {document!.legal_scope && <span><span class="text-outline">Périmètre :</span> {document!.legal_scope}</span>}
          </div>
        </header>

        <h2 class="text-xl font-bold text-on-surface mb-6">Articles</h2>
        {articles.length > 0 ? (
          <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
            {articles.map((a) => (
              <li>
                <a href={articlePath(document!.slug, a.number)} class="flex items-center justify-center h-12 rounded-lg border border-surface-variant bg-surface-container-lowest text-on-surface font-medium hover:border-primary/40 hover:text-primary hover:shadow-sm transition-all text-sm">
                  Art. {a.number}
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <p class="text-on-surface-variant italic">Aucun article publié pour ce texte.</p>
        )}

      </div>
    )}
  </main>
  <Footer />
</Layout>
