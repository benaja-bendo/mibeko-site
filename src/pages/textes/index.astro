---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTASection from '../../components/CTASection.astro';
import {
  fetchPublishedDocuments,
  fetchDocumentTypes,
  documentPath,
  type DocumentMeta,
  type DocumentTypeOption,
  type PaginationMeta,
} from '../../lib/api';

const params = Astro.url.searchParams;
const type = params.get('type') ?? '';
const scope = params.get('scope') ?? '';
const fromRaw = params.get('from') ?? '';
const toRaw = params.get('to') ?? '';
const sort = params.get('sort') ?? 'titre_officiel';
const page = Math.max(1, Number(params.get('page') ?? '1') || 1);
const yearFrom = fromRaw ? Number(fromRaw) : undefined;
const yearTo = toRaw ? Number(toRaw) : undefined;

let documents: DocumentMeta[] = [];
let meta: PaginationMeta = { total: 0, perPage: 24, currentPage: 1, lastPage: 1 };
let types: DocumentTypeOption[] = [];
let loadError = false;

try {
  const [result, typeList] = await Promise.all([
    fetchPublishedDocuments({ type, scope, yearFrom, yearTo, sort, page }),
    fetchDocumentTypes(),
  ]);
  documents = result.items;
  meta = result.meta;
  types = typeList;
} catch {
  loadError = true;
}

const hasFilters = Boolean(type || scope || fromRaw || toRaw || (sort && sort !== 'titre_officiel'));

const currentYear = new Date().getFullYear();
const years = Array.from({ length: currentYear - 1958 }, (_, i) => currentYear - i);

const scopes = [
  { value: 'national', label: 'National' },
  { value: 'ohada', label: 'OHADA' },
  { value: 'communautaire', label: 'Communautaire' },
];
const sorts = [
  { value: 'titre_officiel', label: 'Titre (A→Z)' },
  { value: '-date_publication', label: 'Plus récents' },
  { value: 'date_publication', label: 'Plus anciens' },
];

const dateFmt = (iso?: string | null) =>
  iso ? new Intl.DateTimeFormat('fr-FR', { year: 'numeric' }).format(new Date(iso)) : null;

/** Construit une URL `/textes` en repartant des filtres courants, surchargés. */
const urlWith = (overrides: Record<string, string | number | undefined>) => {
  const sp = new URLSearchParams(params);
  for (const [k, v] of Object.entries(overrides)) {
    if (v === undefined || v === '') sp.delete(k);
    else sp.set(k, String(v));
  }
  const qs = sp.toString();
  return qs ? `/textes?${qs}` : '/textes';
};

const selectClass =
  'h-11 w-full rounded-lg border border-surface-variant bg-surface-container-lowest px-3 text-sm text-on-surface focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary/40';
const labelClass = 'block text-xs font-semibold text-on-surface-variant mb-1.5';
---

<Layout
  title="Textes officiels du Congo — le fonds juridique Mibeko"
  description="Consultez librement les codes, lois, arrêtés et décrets de la République du Congo et de l'espace OHADA. Filtrez par type et par date, naviguez article par article."
>
  <Header />
  <main id="main" class="flex-grow bg-background">

    <section class="pt-20 pb-8 md:pt-28 md:pb-10">
      <div class="max-w-[1120px] mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-semibold uppercase tracking-wider text-secondary mb-3">Le fonds juridique</p>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-on-surface tracking-tight mb-4">Textes officiels du Congo</h1>
        <p class="text-base md:text-lg text-on-surface-variant font-serif max-w-2xl leading-relaxed">
          Codes, lois, arrêtés et décrets de la République du Congo et de l'espace OHADA, consultables article par article, librement.
        </p>
      </div>
    </section>

    <section class="pb-20">
      <div class="max-w-[1120px] mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Barre de filtres (formulaire GET, fonctionne sans JS) -->
        <form method="get" class="mb-8 p-4 sm:p-5 rounded-2xl border border-surface-variant bg-surface-container-low">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4">
            <div>
              <label for="f-type" class={labelClass}>Type</label>
              <select id="f-type" name="type" class={selectClass}>
                <option value="">Tous</option>
                {types.map((t) => (
                  <option value={t.code} selected={t.code === type}>{t.name}</option>
                ))}
              </select>
            </div>
            <div>
              <label for="f-scope" class={labelClass}>Périmètre</label>
              <select id="f-scope" name="scope" class={selectClass}>
                <option value="">Tous</option>
                {scopes.map((s) => (
                  <option value={s.value} selected={s.value === scope}>{s.label}</option>
                ))}
              </select>
            </div>
            <div>
              <label for="f-from" class={labelClass}>Depuis</label>
              <select id="f-from" name="from" class={selectClass}>
                <option value="">Année min.</option>
                {years.map((y) => (
                  <option value={y} selected={String(y) === fromRaw}>{y}</option>
                ))}
              </select>
            </div>
            <div>
              <label for="f-to" class={labelClass}>Jusqu'à</label>
              <select id="f-to" name="to" class={selectClass}>
                <option value="">Année max.</option>
                {years.map((y) => (
                  <option value={y} selected={String(y) === toRaw}>{y}</option>
                ))}
              </select>
            </div>
          </div>
          <div class="mt-4 flex flex-col sm:flex-row sm:items-end gap-3">
            <div class="w-full sm:w-56">
              <label for="f-sort" class={labelClass}>Trier par</label>
              <select id="f-sort" name="sort" class={selectClass}>
                {sorts.map((s) => (
                  <option value={s.value} selected={s.value === sort}>{s.label}</option>
                ))}
              </select>
            </div>
            <div class="flex gap-3 sm:ml-auto">
              <button type="submit" class="h-11 px-6 bg-primary text-on-primary font-semibold rounded-lg hover:bg-primary-container transition-colors text-sm whitespace-nowrap">
                Appliquer les filtres
              </button>
              {hasFilters && (
                <a href="/textes" class="h-11 inline-flex items-center px-4 text-on-surface-variant font-medium rounded-lg border border-surface-variant hover:bg-surface-container transition-colors text-sm">
                  Réinitialiser
                </a>
              )}
            </div>
          </div>
        </form>

        {loadError ? (
          <p class="text-on-surface-variant">Le fonds est momentanément indisponible. Réessayez dans un instant.</p>
        ) : (
          <>
            <p class="text-sm text-on-surface-variant mb-5">
              {meta.total === 0
                ? 'Aucun texte ne correspond à ces critères.'
                : `${meta.total} texte${meta.total > 1 ? 's' : ''}${hasFilters ? ' filtré' + (meta.total > 1 ? 's' : '') : ''}`}
            </p>

            {documents.length > 0 && (
              <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
                {documents.map((d) => (
                  <li>
                    <a href={documentPath(d.slug)} class="flex flex-col h-full p-5 sm:p-6 rounded-2xl border border-surface-variant bg-surface-container-lowest hover:border-primary/40 hover:-translate-y-1 hover:shadow-lg transition-all group">
                      <div class="flex items-center gap-3 mb-4">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-md bg-surface-container text-on-surface-variant text-xs font-semibold uppercase tracking-wider group-hover:bg-secondary/10 group-hover:text-secondary transition-colors">
                          {d.type?.name ?? 'Texte'}
                        </span>
                        {d.date_publication && <span class="text-xs text-outline">{dateFmt(d.date_publication)}</span>}
                      </div>
                      <h2 class="text-base sm:text-lg font-bold text-on-surface group-hover:text-primary transition-colors leading-snug">{d.titre_officiel}</h2>
                      {d.reference_nor && <p class="mt-2 text-sm text-outline">Réf. {d.reference_nor}</p>}
                    </a>
                  </li>
                ))}
              </ul>
            )}

            {meta.lastPage > 1 && (
              <nav class="mt-10 flex items-center justify-between gap-4" aria-label="Pagination">
                {meta.currentPage > 1 ? (
                  <a href={urlWith({ page: meta.currentPage - 1 })} rel="prev" class="inline-flex items-center gap-2 h-11 px-4 sm:px-5 rounded-lg border border-surface-variant text-on-surface font-semibold text-sm hover:border-primary/40 hover:text-primary transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg>
                    <span class="hidden sm:inline">Précédent</span>
                  </a>
                ) : <span></span>}
                <span class="text-sm text-on-surface-variant">Page {meta.currentPage} sur {meta.lastPage}</span>
                {meta.currentPage < meta.lastPage ? (
                  <a href={urlWith({ page: meta.currentPage + 1 })} rel="next" class="inline-flex items-center gap-2 h-11 px-4 sm:px-5 rounded-lg border border-surface-variant text-on-surface font-semibold text-sm hover:border-primary/40 hover:text-primary transition-all">
                    <span class="hidden sm:inline">Suivant</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                  </a>
                ) : <span></span>}
              </nav>
            )}
          </>
        )}
      </div>
    </section>

    <CTASection
      title="Besoin d'aller plus loin qu'une lecture ?"
      text="Expliquez les textes avec Mibeko IA, classez-les en dossiers et recevez les alertes du Journal Officiel dans votre espace."
    />
  </main>
  <Footer />
</Layout>
