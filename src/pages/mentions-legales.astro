---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import PageHeader from '../components/PageHeader.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Mentions légales — Mibeko" description="Mentions légales de la plateforme Mibeko.">
	<Header />
	<main id="main" class="flex-grow">
		<PageHeader eyebrow="Légal" title="Mentions légales" subtitle="Dernière mise à jour : juin 2026" />
		<section class="py-12 md:py-16 bg-background">
			<div class="max-w-[760px] mx-auto px-4 sm:px-6 lg:px-8 legal-prose">
				<!-- <div class="p-4 rounded-lg bg-secondary-container/20 border border-secondary-container/40 mb-8 not-prose">
					<p class="text-sm text-on-secondary-container">⚠️ Modèle à compléter et à faire valider par un conseil juridique avant la mise en ligne définitive. Les informations entre crochets doivent être renseignées.</p>
				</div> -->

				<h2>Éditeur du site</h2>
				<p>
					Le présent site est édité par <strong>Mibeko</strong>, startup, au capital de 1 000 000 FCFA, immatriculée au Registre du Commerce et du Crédit Mobilier (RCCM) sous le numéro 92140945400011, dont le siège social est situé à 186 Av. du Maréchal Gallieni, Mérignac.
				</p>
				<p>
					Adresse e-mail : <a href="mailto:contact@mibeko.fr">contact@mibeko.fr</a><br />
