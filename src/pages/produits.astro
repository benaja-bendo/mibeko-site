---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import PageHeader from '../components/PageHeader.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import imgAppMobile from '../assets/images/produit-app-mobile.webp';
import imgPlateformePro from '../assets/images/produit-plateforme-pro.webp';

const mobileFeatures = [
  {
    title: 'Tout le droit, expliqué simplement',
    description: 'Constitution, codes, lois et textes OHADA, en français clair et avec leur source officielle.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path></svg>`,
  },
  {
    title: 'Un assistant qui répond',
    description: 'Posez vos questions en langage courant. L\'assistant explique et cite les textes correspondants.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"></path><rect width="16" height="12" x="4" y="8" rx="2"></rect><path d="M2 14h2"></path><path d="M20 14h2"></path><path d="M15 13v2"></path><path d="M9 13v2"></path></svg>`,
  },
  {
    title: 'Vos démarches, pas à pas',
    description: 'Suivez une démarche étape par étape, avec les documents à réunir et la base légale.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"></path><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg>`,
  },
  {
    title: 'Vos dossiers, au même endroit',
    description: 'Rassemblez les textes qui vous concernent et retrouvez-les sur tous vos appareils.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>`,
  },
];

const proFeatures = [
  {
    title: 'Recherche avancée',
    description: 'Recherche hybride (lexicale + sémantique) sur tout le fonds, structurée par l\'arborescence des textes.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>`,
  },
  {
    title: 'Assistant IA sourcé',
    description: 'Des réponses avec citations cliquables vers les articles : vous gardez la main sur la source.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"></path><rect width="16" height="12" x="4" y="8" rx="2"></rect><path d="M2 14h2"></path><path d="M20 14h2"></path><path d="M15 13v2"></path><path d="M9 13v2"></path></svg>`,
  },
  {
    title: 'Dossiers & échéances',
    description: 'Organisez vos affaires, calculez et suivez vos délais, et recevez des rappels au bon moment.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M16 2v4"></path><path d="M8 2v4"></path><path d="M3 10h18"></path><path d="m9 16 2 2 4-4"></path></svg>`,
  },
  {
    title: 'Veille & export',
    description: 'Suivez le Journal Officiel et exportez vos textes et dossiers en PDF à l\'identité de votre cabinet.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"></path><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"></path></svg>`,
  },
];
---

<Layout
	title="Nos applications — l'app citoyenne et l'espace pro Mibeko"
	description="Deux expériences pour une même source de droit : l'application pour comprendre vos droits, l'espace professionnel pour travailler plus vite. République du Congo et OHADA."
>
	<Header />
	<main id="main" class="flex-grow">
		<PageHeader
			eyebrow="Nos applications"
			title="Deux expériences, une même source"
			subtitle="L'application pour les citoyens qui veulent comprendre et agir ; l'espace professionnel pour les juristes qui veulent travailler plus vite. Toutes deux puisent dans le même fonds officiel."
		/>

		<!-- APP MOBILE -->
		<section id="mobile" class="py-16 md:py-24 bg-background scroll-mt-24">
			<div class="max-w-[1120px] mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<div>
						<div class="inline-flex items-center px-3 py-1.5 rounded-full bg-primary/10 text-primary text-xs font-semibold tracking-wide uppercase mb-4">Pour les citoyens</div>
						<h2 class="text-3xl md:text-4xl font-bold text-on-surface tracking-tight mb-4">Le droit congolais dans votre poche</h2>
						<p class="text-on-surface-variant font-serif text-lg leading-relaxed mb-8">
							Conçue pour le grand public : posez vos questions en français courant et explorez la loi à votre rythme. Tous les textes sont officiels et sourcés.
						</p>

						<div class="relative w-full max-w-sm aspect-[9/16] rounded-[2rem] overflow-hidden border-8 border-surface-variant shadow-2xl bg-surface-container-low mb-8">
							<Image src={imgAppMobile} alt="Une citoyenne consulte ses droits sur l'application Mibeko" width={800} loading="eager" class="w-full h-full object-cover" />
							<div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
						</div>

						<a href="/contact" class="inline-flex items-center justify-center h-12 px-6 bg-primary text-on-primary font-semibold rounded hover:bg-primary-container transition-colors">
							Être prévenu du lancement
						</a>
						<p class="mt-3 text-sm text-outline">Application Android en préparation.</p>
					</div>

					<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
						{mobileFeatures.map((f) => (
							<div class="bg-surface-container-lowest rounded-2xl p-6 border border-surface-variant hover:border-primary/40 hover:-translate-y-1 hover:shadow-md transition-all">
								<div class="w-11 h-11 bg-primary/10 text-primary rounded-xl flex items-center justify-center mb-4" set:html={f.icon} />
								<h3 class="text-base font-bold text-on-surface mb-2">{f.title}</h3>
								<p class="text-sm text-on-surface-variant leading-relaxed">{f.description}</p>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- PLATEFORME PRO -->
		<section id="pro" class="py-16 md:py-24 bg-surface-container-low border-y border-surface-variant/50 scroll-mt-24">
			<div class="max-w-[1120px] mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<div class="order-2 lg:order-1 grid grid-cols-1 sm:grid-cols-2 gap-4">
						{proFeatures.map((f) => (
							<div class="bg-surface-container-lowest rounded-2xl p-6 border border-surface-variant hover:border-secondary/40 hover:-translate-y-1 hover:shadow-md transition-all">
								<div class="w-11 h-11 bg-secondary/10 text-secondary rounded-xl flex items-center justify-center mb-4" set:html={f.icon} />
								<h3 class="text-base font-bold text-on-surface mb-2">{f.title}</h3>
								<p class="text-sm text-on-surface-variant leading-relaxed">{f.description}</p>
							</div>
						))}
					</div>
					<div class="order-1 lg:order-2">
						<div class="inline-flex items-center px-3 py-1.5 rounded-full bg-secondary/10 text-secondary text-xs font-semibold tracking-wide uppercase mb-4">Pour les professionnels</div>
						<h2 class="text-3xl md:text-4xl font-bold text-on-surface tracking-tight mb-4">Le poste de travail du juriste</h2>
						<p class="text-on-surface-variant font-serif text-lg leading-relaxed mb-8">
							La plateforme web des avocats, notaires, huissiers et juristes d'entreprise : rechercher, analyser, organiser ses dossiers et suivre ses délais — au même endroit.
						</p>

						<div class="relative w-full aspect-video rounded-2xl overflow-hidden border border-surface-variant shadow-2xl bg-surface-container-low mb-8">
							<Image src={imgPlateformePro} alt="Un professionnel du droit utilise la plateforme Mibeko Pro" width={1280} loading="eager" class="w-full h-full object-cover" />
						</div>

						<div class="flex flex-col sm:flex-row gap-3">
							<a href="https://app.mibeko.fr/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center h-12 px-6 bg-primary text-on-primary font-semibold rounded hover:bg-primary-container transition-colors">
								Accéder à l'espace pro
							</a>
							<a href="/contact" class="inline-flex items-center justify-center h-12 px-6 border border-outline-variant/70 text-on-surface font-semibold rounded hover:bg-surface-container transition-colors">
								Demander une démo
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Engagement / confiance -->
		<section class="py-16 bg-background">
			<div class="max-w-[1120px] mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
					<div>
						<p class="text-3xl md:text-4xl font-bold text-primary mb-1">Officiel</p>
						<p class="text-sm text-on-surface-variant">Textes sourcés (JO, sgg.cg)</p>
					</div>
					<div>
						<p class="text-3xl md:text-4xl font-bold text-primary mb-1">OHADA</p>
						<p class="text-sm text-on-surface-variant">Droit des affaires harmonisé</p>
					</div>
					<div>
						<p class="text-3xl md:text-4xl font-bold text-primary mb-1">IA</p>
						<p class="text-sm text-on-surface-variant">Réponses avec citations</p>
					</div>
					<div>
						<p class="text-3xl md:text-4xl font-bold text-primary mb-1">Multi-appareils</p>
						<p class="text-sm text-on-surface-variant">Vos dossiers, synchronisés</p>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA FINAL -->
		<section class="py-16 md:py-24 bg-surface-container-low border-t border-surface-variant/50">
			<div class="max-w-[1120px] mx-auto px-4 sm:px-6 lg:px-8 text-center">
				<h2 class="text-3xl md:text-4xl font-bold text-on-surface mb-4">Commencez dès aujourd'hui</h2>
				<p class="text-on-surface-variant font-serif text-lg mb-8 max-w-2xl mx-auto">
					L'espace professionnel est disponible ; l'application citoyenne arrive bientôt. Vous pouvez déjà consulter tout le fonds librement.
				</p>
				<div class="flex flex-col sm:flex-row gap-3 justify-center">
					<a href="https://app.mibeko.fr/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center h-12 px-8 bg-primary text-on-primary font-semibold rounded hover:bg-primary-container transition-colors">Accéder à l'espace pro</a>
					<a href="/codes" class="inline-flex items-center justify-center h-12 px-8 border border-outline-variant/70 text-on-surface font-semibold rounded hover:bg-surface-container transition-colors">Explorer le fonds</a>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
