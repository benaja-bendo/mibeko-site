---
interface Props {
  title?: string;
  text?: string;
}
const {
  title = "Prêt à reprendre le contrôle de vos droits ?",
  text = "Découvrez nos solutions adaptées à vos besoins, que vous soyez un citoyen ou un professionnel du droit.",
} = Astro.props;
---

<section class="py-24 md:py-32 relative overflow-hidden bg-background">
  <!-- Dynamic Gradient Background -->
  <div class="absolute inset-4 md:inset-8 bg-primary rounded-3xl overflow-hidden shadow-2xl">
    <div class="absolute inset-0 bg-[url('/noise.svg')] opacity-10 mix-blend-overlay"></div>
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-secondary/20 rounded-full blur-[100px] translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-tertiary/20 rounded-full blur-[80px] -translate-x-1/3 translate-y-1/3 pointer-events-none"></div>
  </div>

  <div class="max-w-[800px] mx-auto px-8 sm:px-12 lg:px-16 text-center relative z-10 py-16 md:py-20 text-on-primary">
    <div class="animate-fade-in-up">
      <h2 class="text-4xl md:text-5xl lg:text-[52px] font-bold tracking-tight leading-tight mb-6">
        {title}
      </h2>
      <p class="text-inverse-primary text-xl font-serif leading-relaxed mb-12 max-w-2xl mx-auto">
        {text}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="/produits#mobile" class="inline-flex items-center justify-center h-14 px-8 bg-on-primary text-primary font-bold rounded-xl hover:bg-surface-container-low transition-all duration-300 hover:scale-105 hover:shadow-xl w-full sm:w-auto">
          Découvrir l'App Mobile
        </a>
        <a href="https://app.mibeko.fr/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center h-14 px-8 border-2 border-on-primary/30 text-on-primary font-bold rounded-xl hover:bg-on-primary/10 transition-all duration-300 w-full sm:w-auto">
          Accéder à la Plateforme Pro
        </a>
      </div>
    </div>
  </div>
</section>