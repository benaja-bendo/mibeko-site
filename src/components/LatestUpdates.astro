---
import { fetchPublishedDocuments, documentPath, type DocumentMeta } from '../lib/api';

// Derniers textes réellement publiés dans le fonds. Récupérés au build ; en cas
// d'API indisponible, la section se masque (pas de contenu factice).
let documents: DocumentMeta[] = [];
try {
  documents = await fetchPublishedDocuments(3, '-date_publication');
} catch {
  documents = [];
}

const dateFmt = (iso?: string | null) =>
  iso ? new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(iso)) : null;
---

{documents.length > 0 && (
  <section class="py-20 md:py-32 bg-background relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(var(--color-primary) 1px, transparent 1px); background-size: 32px 32px;"></div>

    <div class="max-w-[1000px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-12 pb-6 border-b border-surface-variant/60 animate-fade-in-up">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-surface-container-low border border-outline-variant/40 mb-4">
            <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
            <span class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Le fonds s'enrichit</span>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-on-surface tracking-tight mb-2 sm:mb-0">
            Derniers textes publiés
          </h2>
        </div>
        <a href="/codes" class="text-sm font-semibold text-secondary hover:text-primary transition-colors inline-flex items-center gap-1 group mt-4 sm:mt-0">
          Explorer le fonds
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform">
            <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <div class="flex flex-col gap-6">
        {documents.map((doc, index) => (
          <a
            href={documentPath(doc.slug)}
            class={`block bg-surface-container-lowest border border-surface-variant rounded-2xl p-6 md:p-8 hover:border-primary/30 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group animate-fade-in-up animation-delay-${(index + 1) * 100}`}
          >
            <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-8">
              <div class="flex-grow">
                <div class="flex items-center gap-3 mb-3 flex-wrap">
                  <span class="inline-flex items-center px-2.5 py-1 rounded bg-secondary/10 text-secondary text-xs font-bold uppercase tracking-wide">
                    {doc.type?.name ?? 'Texte'}
                  </span>
                  {doc.date_publication && <span class="text-sm text-outline font-medium">{dateFmt(doc.date_publication)}</span>}
                  {doc.reference_nor && <span class="text-sm text-outline">· Réf. {doc.reference_nor}</span>}
                </div>
                <h3 class="text-xl md:text-2xl font-bold text-on-surface mb-1 group-hover:text-primary transition-colors leading-snug">
                  {doc.titre_officiel}
                </h3>
              </div>

              <div class="hidden md:flex shrink-0 w-12 h-12 rounded-full border border-surface-variant items-center justify-center text-outline group-hover:border-primary group-hover:bg-primary group-hover:text-on-primary transition-all duration-300 self-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m9 18 6-6-6-6"></path>
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
