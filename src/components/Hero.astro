---
---

<section class="relative pt-14 pb-20 md:pt-20 md:pb-28 overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(70%_60%_at_15%_10%,rgba(253,166,133,0.28),transparent_60%),radial-gradient(55%_50%_at_85%_35%,rgba(197,235,215,0.55),transparent_60%)]"></div>
  <div class="max-w-[1120px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      <div class="max-w-2xl">
        <h1 class="font-sans text-4xl md:text-5xl lg:text-[52px] font-bold text-on-surface leading-[1.12] tracking-tight mb-6">
          La loi, plus simple. <br class="hidden md:block" />
          <span class="text-primary">Dans votre poche.</span>
        </h1>
        <p class="font-serif text-lg md:text-xl text-on-surface-variant leading-relaxed mb-8 max-w-xl">
          Mibeko réunit une bibliothèque juridique fiable et un assistant d’orientation, pour vous aider à trouver le bon texte et comprendre l’essentiel.
        </p>

        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-10">
          <li class="flex items-start gap-3 rounded-xl bg-white/70 border border-surface-variant/60 px-4 py-3">
            <span class="mt-0.5 w-7 h-7 rounded-full bg-primary/10 text-primary flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
            </span>
            <span class="text-sm text-on-surface-variant leading-snug">Textes officiels structurés, faciles à retrouver.</span>
          </li>
          <li class="flex items-start gap-3 rounded-xl bg-white/70 border border-surface-variant/60 px-4 py-3">
            <span class="mt-0.5 w-7 h-7 rounded-full bg-primary/10 text-primary flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"></path><rect width="16" height="12" x="4" y="8" rx="2"></rect><path d="M2 14h2"></path><path d="M20 14h2"></path><path d="M15 13v2"></path><path d="M9 13v2"></path></svg>
            </span>
            <span class="text-sm text-on-surface-variant leading-snug">Questions simples, orientation vers les bons articles.</span>
          </li>
          <li class="flex items-start gap-3 rounded-xl bg-white/70 border border-surface-variant/60 px-4 py-3 sm:col-span-2">
            <span class="mt-0.5 w-7 h-7 rounded-full bg-primary/10 text-primary flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M16 2v4M8 2v4M3 10h18"></path></svg>
            </span>
            <span class="text-sm text-on-surface-variant leading-snug">Prise de rendez-vous avec des professionnels certifiés.</span>
          </li>
        </ul>

        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 items-stretch sm:items-center">
          <a href="/contact" class="inline-flex w-full sm:w-auto items-center justify-center h-12 px-6 bg-primary text-on-primary font-semibold rounded hover:bg-primary-container transition-colors">
            Être prévenu du lancement
          </a>
          <a href="/ressources" class="inline-flex w-full sm:w-auto items-center justify-center h-12 px-6 border border-outline-variant/70 text-on-surface font-semibold rounded hover:bg-surface-container-low transition-colors">
            Voir les ressources
          </a>
          <div class="sm:ml-auto rounded-lg border border-surface-variant bg-white/70 px-3 py-2 text-xs text-on-surface-variant">
            Android & iOS bientôt.
          </div>
        </div>
      </div>

      <div class="relative lg:ml-auto w-full max-w-sm mx-auto lg:max-w-md">
        <div class="absolute -inset-6 bg-primary/5 rounded-[3rem] -z-10"></div>
        <div class="relative rounded-[2.75rem] bg-primary p-[14px] shadow-xl">
          <div class="rounded-[2.25rem] bg-background overflow-hidden border border-on-primary/10">
            <div class="px-6 pt-4 pb-5 bg-primary text-on-primary">
              <div class="flex items-center justify-between text-[10px] font-semibold tracking-wide opacity-95">
                <span>9:41</span>
                <div class="flex items-center gap-1.5">
                  <span class="h-2 w-3 rounded-sm bg-on-primary/60"></span>
                  <span class="h-2 w-4 rounded-sm bg-on-primary/75"></span>
                  <span class="h-2 w-5 rounded-sm bg-on-primary"></span>
                </div>
              </div>

              <div class="mt-4 flex items-center gap-2">
                <div class="w-9 h-9 rounded-xl bg-on-primary/10 flex items-center justify-center">
                  <img src="/logo.svg" alt="" class="w-5 h-5 brightness-0 invert" />
                </div>
                <div class="min-w-0">
                  <p class="text-sm font-bold leading-none tracking-tight">Mibeko</p>
                  <p class="text-[11px] text-inverse-primary leading-none mt-1">Bibliothèque juridique</p>
                </div>
                <div class="ml-auto flex items-center gap-2">
                  <span class="inline-flex items-center rounded-full bg-on-primary/10 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wider text-on-primary">
                    Démo
                  </span>
                  <div class="w-9 h-9 rounded-xl bg-on-primary/10 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/90">
                      <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"></path>
                      <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                    </svg>
                  </div>
                </div>
              </div>

              <div class="mt-4 flex items-center gap-2 rounded-2xl bg-on-primary/12 px-4 py-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/80 shrink-0">
                  <circle cx="11" cy="11" r="8"></circle>
                  <path d="m21 21-4.3-4.3"></path>
                </svg>
                <span class="text-[12px] text-white/85">Rechercher un code, une loi…</span>
                <span class="ml-auto text-[10px] font-semibold tracking-wider text-secondary-fixed">OHADA</span>
              </div>
            </div>

            <div class="p-5 space-y-3">
              <div class="flex items-center justify-between">
                <p class="text-xs font-semibold text-on-surface">Catégories</p>
                <p class="text-[11px] font-semibold text-primary">Voir tout</p>
              </div>

              <div class="flex gap-2 overflow-hidden">
                <span class="inline-flex items-center rounded-full bg-primary/10 text-primary text-[11px] font-semibold px-3 py-1.5">Travail</span>
                <span class="inline-flex items-center rounded-full bg-secondary-container/35 text-on-secondary-container text-[11px] font-semibold px-3 py-1.5">Famille</span>
                <span class="inline-flex items-center rounded-full bg-primary/10 text-primary text-[11px] font-semibold px-3 py-1.5">Logement</span>
              </div>

              <div class="bg-white border border-surface-variant/60 rounded-2xl p-4 shadow-sm">
                <div class="flex items-start gap-3">
                  <div class="w-10 h-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path>
                    </svg>
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="text-xs font-semibold text-on-surface leading-snug">
                      Code du travail — Contrat & préavis
                    </p>
                    <p class="mt-1 text-[11px] text-on-surface-variant leading-snug">
                      Extraits officiels + références d’articles.
                    </p>
                    <div class="mt-3 flex items-center gap-2">
                      <span class="inline-flex items-center gap-1 rounded-full bg-primary/10 text-primary px-2.5 py-1 text-[10px] font-semibold">
                        <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
                        En vigueur
                      </span>
                      <span class="text-[10px] font-semibold tracking-wider text-secondary uppercase">Source JO</span>
                    </div>
                  </div>
                </div>
              </div>

              <div class="bg-white border border-surface-variant/60 rounded-2xl p-4 shadow-sm">
                <div class="flex items-start gap-3">
                  <div class="w-10 h-10 rounded-xl bg-secondary-container/35 text-on-secondary-container flex items-center justify-center shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 8V4H8"></path>
                      <rect width="16" height="12" x="4" y="8" rx="2"></rect>
                      <path d="M2 14h2"></path>
                      <path d="M20 14h2"></path>
                      <path d="M15 13v2"></path>
                      <path d="M9 13v2"></path>
                    </svg>
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="text-xs font-semibold text-on-surface leading-snug">Assistant IA</p>
                    <p class="mt-1 text-[11px] text-on-surface-variant leading-snug">
                      “Quel est le préavis légal en cas de démission ?”
                    </p>
                    <div class="mt-3 grid gap-2">
                      <div class="h-2 w-11/12 bg-surface-variant rounded-full"></div>
                      <div class="h-2 w-9/12 bg-surface-variant rounded-full"></div>
                      <div class="h-2 w-10/12 bg-surface-variant rounded-full"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="bg-white border-t border-surface-variant/60 px-4 py-3">
              <div class="grid grid-cols-4 gap-2">
                <div class="flex flex-col items-center gap-1 text-primary">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><path d="M9 22V12h6v10"></path></svg>
                  <span class="text-[10px] font-semibold">Accueil</span>
                </div>
                <div class="flex flex-col items-center gap-1 text-on-surface-variant">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path></svg>
                  <span class="text-[10px] font-semibold">Bibliothèque</span>
                </div>
                <div class="flex flex-col items-center gap-1 text-on-surface-variant">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
                  <span class="text-[10px] font-semibold">Dossiers</span>
                </div>
                <div class="flex flex-col items-center gap-1 text-on-surface-variant">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                  <span class="text-[10px] font-semibold">Profil</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>
