---
const steps = [
  {
    step: '01',
    title: 'Recherchez',
    description:
      'Trouvez rapidement une loi, un code ou un sujet précis. Même avec des mots simples.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>`,
  },
  {
    step: '02',
    title: 'Comprenez',
    description:
      'Obtenez des explications claires et des références aux textes officiels correspondants.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 17h.01"></path><path d="M12 10a3 3 0 0 1 2 5.24c-.6.5-1 1-1 1.76"></path><circle cx="12" cy="12" r="10"></circle></svg>`,
  },
  {
    step: '03',
    title: 'Passez à l’action',
    description:
      'Prenez rendez-vous avec des professionnels certifiés, selon votre besoin et votre localisation.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M16 2v4"></path><path d="M8 2v4"></path><path d="M3 10h18"></path><path d="m9 16 2 2 4-4"></path></svg>`,
  },
];
---

<section data-draw class="py-16 md:py-24 bg-surface-container-low border-y border-surface-variant/50">
  <div class="max-w-[1120px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12 items-start mb-12 md:mb-16">
      <div class="lg:col-span-5 animate-fade-in-up">
        <h2 class="font-sans text-3xl md:text-[34px] font-bold text-on-surface tracking-tight leading-tight mb-4">
          Rechercher, comprendre, agir.
        </h2>
        <p class="font-serif text-lg text-on-surface-variant leading-relaxed max-w-md">
          Mibeko est conçu pour transformer une question juridique en réponse exploitable, sans jargon inutile.
        </p>
      </div>

      <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {steps.map((s, index) => (
          <div class={`step-card bg-white rounded-2xl border border-surface-variant p-6 md:p-7 shadow-sm hover-lift animate-fade-in-up animation-delay-${(index + 1) * 100}`}>
            <div class="flex items-start justify-between gap-4 mb-5">
              <div class="icon-draw w-11 h-11 rounded-xl bg-secondary-container text-on-secondary-container flex items-center justify-center">
                <Fragment set:html={s.icon} />
              </div>
              <span class="text-xs font-semibold tracking-wider text-outline">{s.step}</span>
            </div>
            <h3 class="font-sans text-lg font-semibold text-on-surface mb-2">{s.title}</h3>
            <p class="font-sans text-sm text-on-surface-variant leading-relaxed">{s.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var el = document.querySelector('[data-draw]');
    if (!el) return;
    // Respecte la réduction de mouvement : on laisse les icônes visibles, sans tracé animé
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (!('IntersectionObserver' in window)) return;
    el.classList.add('draw-ready');
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { el.classList.add('drawn'); io.unobserve(el); }
      });
    }, { threshold: 0.3 });
    io.observe(el);
  })();
</script>
