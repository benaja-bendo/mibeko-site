---
---

<section class="py-20 md:py-28 bg-background">
  <div class="max-w-[1120px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mb-12 animate-fade-in-up">
      <p class="text-sm font-semibold uppercase tracking-wider text-secondary mb-3">Pour qui ?</p>
      <h2 class="text-3xl md:text-4xl font-bold text-on-surface tracking-tight">Deux expériences, une même source</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Citoyen -->
      <a href="/produits#mobile" class="group flex flex-col p-8 md:p-10 rounded-3xl border border-surface-variant bg-surface-container-lowest hover:border-primary/40 hover:shadow-lg transition-all duration-300">
        <div class="flex items-center gap-4 mb-5">
          <span class="w-14 h-14 rounded-2xl bg-surface-container text-on-surface flex items-center justify-center group-hover:bg-primary group-hover:text-on-primary transition-colors shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>
          </span>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-outline mb-1">Citoyen</p>
            <h3 class="text-2xl font-bold text-on-surface group-hover:text-primary transition-colors">L'application mobile</h3>
          </div>
        </div>
        <p class="text-on-surface-variant font-serif leading-relaxed mb-6">
          Le droit congolais dans votre poche : comprenez vos droits, suivez vos démarches et recevez les mises à jour qui vous concernent.
        </p>
        <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary mt-auto">
          Découvrir l'app
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </span>
      </a>

      <!-- Professionnel -->
      <a href="https://app.mibeko.fr/" target="_blank" rel="noopener noreferrer" class="group flex flex-col p-8 md:p-10 rounded-3xl border border-surface-variant bg-surface-container-lowest hover:border-secondary/40 hover:shadow-lg transition-all duration-300">
        <div class="flex items-center gap-4 mb-5">
          <span class="w-14 h-14 rounded-2xl bg-secondary/10 text-secondary flex items-center justify-center group-hover:bg-secondary group-hover:text-on-secondary transition-colors shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
          </span>
          <div>
            <div class="flex items-center gap-2 mb-1">
              <p class="text-xs font-semibold uppercase tracking-wider text-outline">Professionnel</p>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-primary/10 text-primary uppercase tracking-wider">Disponible</span>
            </div>
            <h3 class="text-2xl font-bold text-on-surface group-hover:text-primary transition-colors">La plateforme Pro</h3>
          </div>
        </div>
        <p class="text-on-surface-variant font-serif leading-relaxed mb-6">
          Recherche avancée, assistant IA, dossiers et échéances, export : le poste de travail des professionnels du droit.
        </p>
        <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-secondary mt-auto">
          Accéder à l'espace Pro
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </span>
      </a>
    </div>
  </div>
</section>
