---
---

<section id="about" class="section about-section">
	<div class="container about-container">
		<div class="about-content">
			<span class="section-subtitle text-gold">Notre Mission</span>
			<h2 class="section-title text-white">L'IA au service de la justice congolaise</h2>
			
			<div class="about-text text-gray">
				<p>
					Chez Mibeko, nous sommes convaincus que l'accès au droit est un pilier fondamental de toute société démocratique. Notre mission est de démocratiser l'accès aux textes juridiques en République du Congo grâce aux dernières avancées en intelligence artificielle.
				</p>
				<p>
					Notre moteur de recherche repose sur une <strong>vectorisation sémantique avancée</strong> des lois congolaises. Cela signifie que l'application ne cherche pas seulement des mots, mais comprend le <em>sens</em> de votre requête. Couplé à notre IA générative spécialisée, Mibeko est capable d'analyser, de synthétiser et de vous orienter vers la bonne information juridique en quelques millisecondes.
				</p>
			</div>

			<div class="tech-stack">
				<div class="tech-item">
					<span class="tech-dot"></span>
					<span>Vectorisation Hybride</span>
				</div>
				<div class="tech-item">
					<span class="tech-dot"></span>
					<span>Base de données sécurisée</span>
				</div>
				<div class="tech-item">
					<span class="tech-dot"></span>
					<span>Conformité RGPD</span>
				</div>
				<div class="tech-item">
					<span class="tech-dot"></span>
					<span>Mises à jour OTA</span>
				</div>
			</div>
		</div>

		<div class="about-visual">
			<div class="ai-visualization">
				<div class="circle circle-1"></div>
				<div class="circle circle-2"></div>
				<div class="circle circle-3"></div>
				
				<div class="nodes-container">
					<!-- Generated visually with CSS -->
					<div class="node n1"><span>Droit Pénal</span></div>
					<div class="node n2"><span>Code Civil</span></div>
					<div class="node n3"><span>Constitution</span></div>
					<div class="node n4"><span>Droit du Travail</span></div>
					<div class="center-node">IA Mibeko</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.about-section {
		background-color: var(--color-navy);
		padding: 8rem 0;
		position: relative;
		overflow: hidden;
	}

	.about-container {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.section-subtitle {
		display: block;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 2px;
		font-size: 0.85rem;
		margin-bottom: 0.5rem;
	}

	.section-title {
		font-size: 2.5rem;
		margin-bottom: 2rem;
		line-height: 1.2;
	}

	.about-text p {
		font-size: 1.1rem;
		line-height: 1.8;
		margin-bottom: 1.5rem;
	}

	.about-text strong {
		color: var(--color-white);
	}

	.about-text em {
		color: var(--color-gold);
		font-style: normal;
	}

	.tech-stack {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid rgba(255,255,255,0.1);
	}

	.tech-item {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		color: var(--color-white);
		font-size: 0.95rem;
		font-weight: 500;
	}

	.tech-dot {
		width: 8px;
		height: 8px;
		background-color: var(--color-gold);
		border-radius: 50%;
		box-shadow: 0 0 10px var(--color-gold);
	}

	.about-visual {
		position: relative;
		height: 500px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.ai-visualization {
		position: relative;
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.circle {
		position: absolute;
		border-radius: 50%;
		border: 1px dashed rgba(255,255,255,0.1);
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
	}

	.circle-1 { width: 250px; height: 250px; animation: spin 20s linear infinite; border-color: rgba(212, 175, 55, 0.3); }
	.circle-2 { width: 350px; height: 350px; animation: spin-reverse 30s linear infinite; }
	.circle-3 { width: 450px; height: 450px; animation: spin 40s linear infinite; }

	.nodes-container {
		position: absolute;
		width: 100%;
		height: 100%;
		top: 0;
		left: 0;
	}

	.center-node {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 100px;
		height: 100px;
		background-color: var(--color-navy-light);
		border: 2px solid var(--color-gold);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--color-gold);
		font-weight: 700;
		font-size: 0.9rem;
		box-shadow: 0 0 30px rgba(212, 175, 55, 0.2);
		z-index: 10;
	}

	.node {
		position: absolute;
		padding: 0.5rem 1rem;
		background-color: var(--color-navy-lighter);
		color: var(--color-gray);
		border-radius: 20px;
		font-size: 0.8rem;
		border: 1px solid rgba(255,255,255,0.05);
		transition: all 0.3s ease;
	}

	.node:hover {
		color: var(--color-white);
		border-color: var(--color-gold);
		box-shadow: 0 0 15px rgba(212, 175, 55, 0.2);
	}

	.n1 { top: 20%; left: 20%; }
	.n2 { top: 15%; right: 25%; }
	.n3 { bottom: 25%; right: 15%; }
	.n4 { bottom: 20%; left: 25%; }

	@keyframes spin {
		0% { transform: translate(-50%, -50%) rotate(0deg); }
		100% { transform: translate(-50%, -50%) rotate(360deg); }
	}

	@keyframes spin-reverse {
		0% { transform: translate(-50%, -50%) rotate(360deg); }
		100% { transform: translate(-50%, -50%) rotate(0deg); }
	}

	@media (max-width: 992px) {
		.about-container {
			grid-template-columns: 1fr;
		}

		.about-visual {
			height: 400px;
			margin-top: 2rem;
		}

		.circle-3 {
			display: none;
		}
	}
</style>
