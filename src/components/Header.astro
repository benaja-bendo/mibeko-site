---
const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/produits', label: 'Produits' },
  { href: '/ressources', label: 'Ressources' },
  { href: '/contact', label: 'Contact' },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="sticky top-0 z-50 w-full bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/80 border-b border-surface-variant/60">
  <div class="max-w-[1120px] mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group" aria-label="Mibeko — Accueil">
      <img src="/logo.svg" alt="" class="w-8 h-8 group-hover:opacity-90 transition-opacity" />
      <span class="font-sans font-bold text-xl text-primary tracking-tight">Mibeko</span>
    </a>

    <!-- Navigation (Desktop) -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Navigation principale">
      {navLinks.map((link) => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? 'page' : undefined}
          class:list={[
            "text-sm font-medium transition-colors relative py-2",
            isActive(link.href) ? "text-primary" : "text-on-surface-variant hover:text-primary"
          ]}
        >
          {link.label}
          {isActive(link.href) && (
            <span class="absolute bottom-0 left-0 w-full h-[2px] bg-secondary rounded-t-full"></span>
          )}
        </a>
      ))}
    </nav>

    <!-- Actions (Desktop) -->
    <div class="hidden md:flex items-center gap-6">
      <a href="/produits#mobile" class="text-sm font-medium text-on-surface-variant hover:text-primary transition-colors">
        L'App Mobile
      </a>
      <a
        href="https://app.mibeko.fr/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center h-10 px-5 text-sm font-medium text-on-primary bg-primary rounded hover:bg-primary-container transition-colors"
      >
        Accès Pro
      </a>
    </div>

    <!-- Mobile menu button (Hamburger) -->
    <button
      id="mobile-menu-toggle"
      type="button"
      class="md:hidden p-2 -mr-2 text-on-surface-variant hover:text-primary"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg data-icon="open" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" x2="20" y1="12" y2="12"></line>
        <line x1="4" x2="20" y1="6" y2="6"></line>
        <line x1="4" x2="20" y1="18" y2="18"></line>
      </svg>
      <svg data-icon="close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" x2="6" y1="6" y2="18"></line>
        <line x1="6" x2="18" y1="6" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Mobile menu panel -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-surface-variant/60 bg-background">
    <nav class="max-w-[1120px] mx-auto px-4 sm:px-6 py-4 flex flex-col" aria-label="Navigation mobile">
      {navLinks.map((link) => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? 'page' : undefined}
          class:list={[
            "py-3 text-base font-medium border-b border-surface-variant/40 transition-colors",
            isActive(link.href) ? "text-primary" : "text-on-surface-variant hover:text-primary"
          ]}
        >
          {link.label}
        </a>
      ))}
      <a href="/produits#mobile" class="py-3 text-base font-medium border-b border-surface-variant/40 transition-colors text-on-surface-variant hover:text-primary">
        L'App Mobile
      </a>
      <a
        href="https://app.mibeko.fr/"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-flex items-center justify-center h-11 px-5 text-sm font-medium text-on-primary bg-primary rounded hover:bg-primary-container transition-colors"
      >
        Accès Pro
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const openIcon = toggle?.querySelector('[data-icon="open"]');
  const closeIcon = toggle?.querySelector('[data-icon="close"]');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Fermer le menu' : 'Ouvrir le menu');
    openIcon?.classList.toggle('hidden', isOpen);
    closeIcon?.classList.toggle('hidden', !isOpen);
  });
</script>
