---

<section id="audience" class="section audience-section">
	<div class="container">
		<div class="section-header">
			<span class="section-subtitle text-gold">Pour qui ?</span>
			<h2 class="section-title text-navy">Une solution adaptée à votre profil</h2>
		</div>

		<div class="audience-grid">
			<!-- Audience 1 -->
			<div class="audience-card">
				<div class="card-bg"></div>
				<div class="card-content">
					<div class="card-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
					</div>
					<h3 class="card-title">Professionnels du Droit</h3>
					<ul class="card-list">
						<li>Avocats, magistrats, notaires</li>
						<li>Recherche jurisprudentielle rapide</li>
						<li>Gain de temps en audience</li>
						<li>Bibliothèque juridique portable</li>
					</ul>
				</div>
			</div>

			<!-- Audience 2 -->
			<div class="audience-card featured">
				<div class="card-bg"></div>
				<div class="card-content">
					<div class="card-icon featured-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path></svg>
					</div>
					<h3 class="card-title text-white">Étudiants</h3>
					<ul class="card-list text-gray">
						<li>Facultés de droit, ENAM</li>
						<li>Préparation aux examens</li>
						<li>Explications simplifiées par l'IA</li>
						<li>Accès complet aux codes</li>
					</ul>
				</div>
			</div>

			<!-- Audience 3 -->
			<div class="audience-card">
				<div class="card-bg"></div>
				<div class="card-content">
					<div class="card-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
					</div>
					<h3 class="card-title">Citoyens & Entreprises</h3>
					<ul class="card-list">
						<li>Compréhension de vos droits</li>
						<li>Vulgarisation juridique</li>
						<li>Démarches administratives</li>
						<li>Sécurité juridique des affaires</li>
					</ul>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.audience-section {
		background-color: var(--color-gray-light);
		padding: 8rem 0;
	}

	.section-header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.section-subtitle {
		display: block;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 2px;
		font-size: 0.85rem;
		margin-bottom: 0.5rem;
	}

	.section-title {
		font-size: 2.5rem;
	}

	.audience-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
		align-items: center;
	}

	.audience-card {
		position: relative;
		background-color: var(--color-white);
		border-radius: 20px;
		overflow: hidden;
		box-shadow: 0 15px 35px rgba(0,0,0,0.05);
		transition: transform 0.3s ease;
		height: 100%;
		display: flex;
		flex-direction: column;
	}

	.audience-card:hover {
		transform: translateY(-10px);
	}

	.audience-card.featured {
		background-color: var(--color-navy);
		color: var(--color-white);
		transform: scale(1.05);
		box-shadow: 0 25px 50px rgba(10, 25, 47, 0.2);
		z-index: 2;
	}

	.audience-card.featured:hover {
		transform: scale(1.05) translateY(-10px);
	}

	.card-content {
		padding: 3rem 2.5rem;
		position: relative;
		z-index: 2;
		flex-grow: 1;
	}

	.card-icon {
		color: var(--color-navy);
		background-color: var(--color-gray-light);
		width: 70px;
		height: 70px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 2rem;
	}

	.featured-icon {
		background-color: rgba(212, 175, 55, 0.1);
		color: var(--color-gold);
	}

	.card-title {
		font-size: 1.5rem;
		margin-bottom: 1.5rem;
		color: var(--color-navy);
	}

	.card-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.card-list li {
		position: relative;
		padding-left: 1.5rem;
		color: var(--color-gray);
		line-height: 1.5;
	}

	.card-list li::before {
		content: '→';
		position: absolute;
		left: 0;
		top: 0;
		color: var(--color-gold);
		font-weight: bold;
	}

	@media (max-width: 992px) {
		.audience-grid {
			grid-template-columns: 1fr;
			max-width: 500px;
			margin: 0 auto;
		}

		.audience-card.featured {
			transform: none;
		}

		.audience-card.featured:hover {
			transform: translateY(-10px);
		}
	}
</style>
