---
const year = new Date().getFullYear();

const columns = [
  {
    title: 'Le droit',
    links: [
      { href: '/textes', label: 'Textes officiels' },
      { href: '/themes', label: 'Par thème' },
      { href: '/demarches', label: 'Démarches' },
      { href: '/ressources', label: 'Guides' },
      { href: '/recherche', label: 'Rechercher' },
    ],
  },
  {
    title: 'Plateforme',
    links: [
      { href: '/produits', label: 'Nos produits' },
      { href: '/produits#mobile', label: "L'app mobile" },
      { href: 'https://app.mibeko.fr/', label: 'Espace Pro' },
      { href: '/contact', label: 'Contact' },
    ],
  },
  {
    title: 'Légal',
    links: [
      { href: '/mentions-legales', label: 'Mentions légales' },
      { href: '/cgu', label: "Conditions d'utilisation" },
      { href: '/confidentialite', label: 'Confidentialité' },
    ],
  },
];
---

<footer class="bg-primary text-on-primary pt-12 md:pt-16 mt-auto">
  <div class="max-w-[1120px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8 md:gap-12">
      <!-- Brand -->
      <div class="col-span-2 flex flex-col gap-4">
        <a href="/" class="flex items-center gap-2 w-fit">
          <img src="/logo.svg" alt="" class="w-6 h-6 brightness-0 invert" />
          <span class="font-sans font-bold text-lg tracking-tight">Mibeko</span>
        </a>
        <p class="text-inverse-primary text-sm leading-relaxed max-w-xs">
          Vos droits, simplifiés. La plateforme juridique du Congo et de l'espace OHADA.
        </p>
        <div class="flex gap-3 mt-2">
          <a href="https://www.linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="w-9 h-9 rounded-full border border-inverse-primary/40 flex items-center justify-center text-inverse-primary hover:text-white hover:border-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </a>
          <a href="https://www.facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-9 h-9 rounded-full border border-inverse-primary/40 flex items-center justify-center text-inverse-primary hover:text-white hover:border-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a>
          <a href="mailto:contact@mibeko.fr" aria-label="E-mail" class="w-9 h-9 rounded-full border border-inverse-primary/40 flex items-center justify-center text-inverse-primary hover:text-white hover:border-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Link columns -->
      {columns.map((col) => (
        <div class="flex flex-col gap-4">
          <h3 class="font-sans font-semibold text-sm">{col.title}</h3>
          <ul class="flex flex-col gap-3">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="text-inverse-primary hover:text-white text-sm transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-6 pb-8 border-t border-inverse-primary/20 flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
      <p class="text-inverse-primary text-xs">
        © {year} Mibeko. Tous droits réservés.
      </p>
      <p class="text-inverse-primary/80 text-xs">
        Développé avec le soutien de juristes congolais · Conforme à la loi n°29-2019 sur la protection des données.
      </p>
    </div>
  </div>
</footer>
