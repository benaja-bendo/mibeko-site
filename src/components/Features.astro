---
const features = [
  {
    title: 'Bibliothèque Juridique',
    description: 'Accédez en hors-ligne à la constitution, aux codes, aux lois et aux parutions du Journal Officiel. Une base de données mise à jour et structurée.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path></svg>`,
    active: false,
    alert: null
  },
  {
    title: 'Assistant IA',
    description: 'Posez vos questions en langage courant. L\'assistant vous oriente vers les textes de loi pertinents pour comprendre votre situation.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"></path><rect width="16" height="12" x="4" y="8" rx="2"></rect><path d="M2 14h2"></path><path d="M20 14h2"></path><path d="M15 13v2"></path><path d="M9 13v2"></path></svg>`,
    active: true,
    alert: 'Information à titre indicatif uniquement. Ne remplace en aucun cas les conseils d\'un avocat ou d\'un juriste qualifié.'
  },
  {
    title: 'Prise de Rendez-vous',
    description: 'Trouvez rapidement un avocat, un notaire ou un huissier certifié près de chez vous et réservez une consultation en quelques clics.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect><line x1="16" x2="16" y1="2" y2="6"></line><line x1="8" x2="8" y1="2" y2="6"></line><line x1="3" x2="21" y1="10" y2="10"></line></svg>`,
    active: false,
    alert: null
  }
];
---

<section class="py-20 md:py-24 bg-surface-container-lowest">
  <div class="max-w-[1120px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h2 class="font-sans text-3xl md:text-[32px] font-semibold text-on-surface mb-4">
        Des outils pensés pour vous
      </h2>
      <p class="font-sans text-on-surface-variant">
        Naviguez à travers les textes complexes avec des fonctionnalités conçues pour simplifier votre compréhension et faciliter vos démarches.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {features.map((feature) => (
        <div class:list={[
          "p-8 rounded-xl border flex flex-col bg-white",
          feature.active ? "border-t-2 border-t-secondary border-x-surface-variant border-b-surface-variant shadow-sm" : "border-surface-variant"
        ]}>
          <div class:list={[
            "w-10 h-10 rounded flex items-center justify-center mb-6",
            feature.active ? "bg-secondary-container text-on-secondary-container" : "bg-primary text-on-primary"
          ]} set:html={feature.icon} />
          
          <h3 class="font-sans text-xl font-semibold text-on-surface mb-3">
            {feature.title}
          </h3>
          
          <p class="font-sans text-sm text-on-surface-variant leading-relaxed mb-6 flex-grow">
            {feature.description}
          </p>

          {feature.alert && (
            <div class="mt-auto p-3 rounded bg-error-container/50 border border-error-container text-on-error-container text-xs flex gap-2 items-start">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" x2="12" y1="8" y2="12"></line>
                <line x1="12" x2="12.01" y1="16" y2="16"></line>
              </svg>
              <p>{feature.alert}</p>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
