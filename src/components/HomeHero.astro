---
const quickLinks = [
  { href: '/textes', label: 'Textes officiels' },
  { href: '/demarches', label: 'Démarches' },
  { href: '/ressources', label: 'Guides' },
];
---

<section class="relative pt-24 pb-16 md:pt-32 md:pb-24 overflow-hidden bg-background">
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute -top-40 -right-40 w-[600px] h-[600px] bg-primary/5 rounded-full blur-3xl"></div>
    <div class="absolute top-40 -left-40 w-[500px] h-[500px] bg-secondary/5 rounded-full blur-3xl"></div>
    <div class="absolute inset-0 bg-[url('/noise.svg')] opacity-[0.015] mix-blend-overlay"></div>
  </div>

  <div class="max-w-[820px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center animate-fade-in-up">
    <p class="text-sm font-semibold uppercase tracking-wider text-secondary mb-5">République du Congo · espace OHADA</p>

    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-on-surface tracking-tight leading-[1.1] mb-6">
      Le droit congolais,{' '}
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">clair et à portée de main.</span>
    </h1>

    <p class="text-lg md:text-xl text-on-surface-variant font-serif leading-relaxed mb-10 max-w-2xl mx-auto">
      Cherchez un texte, comprenez un sujet, suivez une démarche. Une plateforme unique pour les citoyens et les professionnels du droit.
    </p>

    <form action="/recherche" method="get" class="relative max-w-xl mx-auto" role="search">
      <div class="flex items-center bg-surface-container-lowest border border-outline-variant/60 rounded-xl shadow-sm hover:shadow-md focus-within:shadow-md focus-within:border-primary focus-within:ring-2 focus-within:ring-primary/20 transition-all p-2 pl-5 group">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-on-surface-variant/60 group-focus-within:text-primary transition-colors shrink-0">
          <circle cx="11" cy="11" r="8"></circle><line x1="21" x2="16.65" y1="21" y2="16.65"></line>
        </svg>
        <label for="hero-search" class="sr-only">Rechercher un droit, une loi ou un thème</label>
        <input id="hero-search" name="q" type="search" placeholder="Ex : « bail commercial », « divorce », « article 230 »…" class="flex-1 bg-transparent border-none outline-none px-4 py-3 text-on-surface placeholder:text-on-surface-variant/50 text-base w-full" />
        <button type="submit" class="bg-primary text-on-primary px-6 py-3 rounded-lg text-sm font-semibold hover:bg-primary-container transition-transform active:scale-95 shrink-0">Rechercher</button>
      </div>
    </form>

    <div class="mt-6 flex flex-wrap items-center justify-center gap-x-2 gap-y-2 text-sm">
      <span class="text-on-surface-variant">Ou parcourez :</span>
      {quickLinks.map((link) => (
        <a href={link.href} class="inline-flex items-center px-3 py-1.5 rounded-full border border-surface-variant text-on-surface hover:border-primary/40 hover:text-primary transition-colors font-medium">
          {link.label}
        </a>
      ))}
    </div>
  </div>
</section>
