---
---

<section class="pt-16 pb-12 md:pt-24 md:pb-20 px-4 overflow-hidden">
  <div class="max-w-[1120px] mx-auto text-center animate-fade-in-up">
    
    <!-- Hero Title & Subtitle -->
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-on-surface tracking-tight mb-6">
      Vos droits, simplifiés.
    </h1>
    <p class="text-lg md:text-xl text-on-surface-variant mb-12 max-w-2xl mx-auto font-serif">
      Recherchez, comprenez, agissez. La plateforme juridique congolaise pour tous.
    </p>
    
    <!-- Search Bar -->
    <form action="/application" method="get" class="max-w-2xl mx-auto mb-20 relative animate-fade-in-up animation-delay-100">
      <div class="flex items-center bg-white border border-outline-variant rounded shadow-sm focus-within:border-primary focus-within:ring-1 focus-within:ring-primary transition-all p-1.5 pl-5">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-on-surface-variant shrink-0">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" x2="16.65" y1="21" y2="16.65"></line>
        </svg>
        <label for="hero-search" class="sr-only">Rechercher un droit, une loi ou un modèle</label>
        <input
          id="hero-search"
          name="q"
          type="text"
          placeholder="Ex : 'bail commercial', 'divorce', 'créer une SARL'"
          class="flex-1 bg-transparent border-none outline-none px-4 py-3 md:py-3.5 text-on-surface placeholder:text-on-surface-variant/70 text-base"
        />
        <button type="submit" class="bg-primary text-on-primary px-6 md:px-8 py-3 md:py-3.5 rounded text-sm md:text-base font-semibold hover:bg-primary-container transition-colors shrink-0">
          Rechercher
        </button>
      </div>
    </form>

    <!-- Main Action Cards -->
    <div class="grid md:grid-cols-2 gap-6 lg:gap-8 text-left animate-fade-in-up animation-delay-200">
      
      <!-- Card Particuliers -->
      <div class="bg-surface-container-lowest border border-surface-variant border-t-[3px] border-t-secondary rounded-xl p-8 md:p-10 relative overflow-hidden group hover-lift">
        <!-- Background Icon (Watermark) -->
        <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="absolute -right-8 -top-8 text-surface-variant/50 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-500">
          <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>

        <div class="w-12 h-12 bg-surface-container rounded-lg flex items-center justify-center text-on-surface mb-6 relative z-10">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-on-surface mb-4 relative z-10">Carte Particuliers</h2>
        <p class="text-on-surface-variant mb-8 min-h-[48px] relative z-10">
          "Je cherche une loi, un modèle de contrat, une information fiable"
        </p>
        <a href="/application" class="inline-flex items-center justify-center gap-2 bg-primary text-on-primary w-full px-6 py-3.5 rounded font-semibold hover:bg-primary-container transition-colors relative z-10">
          Voir l'application
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>

      <!-- Card Professionnels -->
      <div class="bg-surface-container-lowest border border-surface-variant border-t-[3px] border-t-primary rounded-xl p-8 md:p-10 relative overflow-hidden group hover-lift">
        <!-- Background Icon (Watermark) -->
        <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="absolute -right-8 -top-8 text-surface-variant/50 group-hover:scale-110 group-hover:-rotate-3 transition-transform duration-500">
          <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
          <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
        </svg>

        <div class="w-12 h-12 bg-secondary-container/30 text-secondary rounded-lg flex items-center justify-center mb-6 relative z-10">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-on-surface mb-4 relative z-10">Carte Professionnels</h2>
        <p class="text-on-surface-variant mb-8 min-h-[48px] relative z-10">
          "Je veux gagner du temps en recherche, générer des documents, suivre l'actualité OHADA"
        </p>
        <a href="/professionnels" class="inline-flex items-center justify-center gap-2 bg-transparent text-on-surface border border-outline w-full px-6 py-3.5 rounded font-semibold hover:bg-surface-container transition-colors relative z-10">
          Découvrir l'offre Pro
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
            <polyline points="15 3 21 3 21 9"></polyline>
            <line x1="10" y1="14" x2="21" y2="3"></line>
          </svg>
        </a>
      </div>

    </div>
  </div>
</section>
